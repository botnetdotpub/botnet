[Unit]
Description=AI Bot Identity Registry (%i)
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/botid
Environment=RUST_LOG=info
EnvironmentFile=-/etc/identity-registry/%i.env
ExecStart=/usr/local/bin/identity-server
Restart=always
RestartSec=2
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/botid
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
